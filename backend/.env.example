# ============================================================
# HEALY Backend — Environment Variables Template
# Referensi: HEALY_Master_Blueprint v2.1.0 Section 7.1
# ============================================================
# Salin file ini: cp .env.example .env
# Lalu isi nilai yang kosong sesuai project Supabase kamu.
# ============================================================

# ── Server ───────────────────────────────────────────────────
APP_PORT=8080
APP_ENV=development              # development | production

# ── Database (Supabase PostgreSQL) ───────────────────────────
# PENTING: Gunakan Transaction Pooler (port 6543), bukan Direct (5432).
# Format username Pooler: postgres.[project-ref]
# Ambil dari: Supabase Dashboard > Project Settings > Database > Connection string
#
# Development (Direct Connection — untuk migration):
# DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require
#
# Production (Transaction Pooler — untuk runtime app):
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

# ── JWT Authentication ────────────────────────────────────────
# Minimal 32 karakter. Generate dengan: openssl rand -base64 32
JWT_SECRET=your-secret-key-minimum-32-characters-long
JWT_EXPIRY_HOURS=24

# ── CORS ─────────────────────────────────────────────────────
# Pisahkan multiple origins dengan koma (tanpa spasi).
# Development:  http://localhost:3000
# Production:   http://localhost:3000,https://healy.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://healy.vercel.app

# ── WebSocket Paths ───────────────────────────────────────────
WS_DEVICE_PATH=/ws/device        # ESP32 connect ke sini
WS_CLIENT_PATH=/ws/telemetry     # Frontend connect ke sini

# ── AI Voice Assistant (F-05 — Push-to-Talk) ──────────────────
# Groq Whisper STT: https://console.groq.com/keys  (format: gsk_...)
GROQ_API_KEY=
# Google Gemini reasoning + native TTS: https://aistudio.google.com/apikey
# Gunakan AI Studio key (format: AIza...). Tanpa keduanya, voice assistant
# otomatis DISABLED (fitur lain tetap jalan).
GEMINI_API_KEY=
