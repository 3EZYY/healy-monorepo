# ============================================================
# HEALY Frontend — Environment Variables Template
# Referensi: HEALY_Master_Blueprint v2.1.0 Section 7.2
# ============================================================
# Salin file ini: cp .env.example .env.local
# Semua variabel NEXT_PUBLIC_* akan di-expose ke browser.
# ============================================================

# ── WebSocket URL ─────────────────────────────────────────────
# Development:  ws://localhost:8080/ws/telemetry
# Production:   wss://healy-backend.railway.app/ws/telemetry
# PENTING: Gunakan wss:// (bukan ws://) di production (HTTPS).
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws/telemetry

# ── REST API Base URL ─────────────────────────────────────────
# Development:  http://localhost:8080/api
# Production:   https://healy-backend.railway.app/api
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# ── Feature Flags ─────────────────────────────────────────────
# Set true untuk development tanpa hardware ESP32.
# Set false saat backend nyata sudah berjalan.
NEXT_PUBLIC_USE_MOCK_DATA=true

# ── Demo Credentials (Development Only) ──────────────────────
# Hardcoded untuk kemudahan development. JANGAN gunakan di production.
NEXT_PUBLIC_DEMO_USER=admin
NEXT_PUBLIC_DEMO_PASS=healy123
